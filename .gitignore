# =========================
# Go build artifacts
# =========================
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Go coverage
*.coverprofile

# =========================
# Binary output
# =========================
/bin/
/build/
/dist/

# =========================
# Vendor（看情况）
# =========================
# 如果你用 go mod，一般不需要提交 vendor
/vendor/

# =========================
# IDE / Editor
# =========================
.vscode/
.idea/
*.swp
*.swo
*.log

# =========================
# OS 文件
# =========================
.DS_Store
Thumbs.db

# =========================
# Env / config
# =========================
.env
.env.*
*.local

# =========================
# Go workspace
# =========================
go.work
go.work.sum

# =========================
# Debug
# =========================
__debug_bin

# =========================
# Test cache
# =========================
*.test
*.prof

# =========================
# Temporary files
# =========================
tmp/
temp/
# =========================
# Runtime data（很关键）
# =========================
data/
logs/
*.db
*.sqlite
*.sqlite3

# 区块同步缓存
cache/
state/

# =========================
# Config secrets（非常重要）
# =========================
config/*.yaml
config/*.json
!config/example.yaml   # 保留示例配置

# 私钥 / API key
*.key
*.pem
*.p12

# =========================
# Docker
# =========================
docker-compose.override.yml

# =========================
# Generated files
# =========================
*.gen.go